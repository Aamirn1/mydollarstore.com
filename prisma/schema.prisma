// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password   String?
  phone     String?
  address   String?
  city      String?
  role      String   @default("customer") // customer, admin, partner
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders              Order[]
  reviews             Review[]
  partnerApplication  PartnerApplication?
  partnerPayouts      PartnerPayout[]
}

model Product {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  price         Float
  originalPrice Float?
  categorySlug  String
  imageUrl      String?
  images        String?  // JSON string for multiple images
  description   String?
  specifications String? // JSON string for drone specs (flightTime, range, camera, weight, maxSpeed, gps, gimbal, sensors, battery)
  rating        Float    @default(0)
  reviewCount   Int      @default(0)
  tag           String?  // Best Seller, New, Popular, Sale
  brand         String?
  inStock       Boolean  @default(true)
  stockCount    Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reviews Review[]
}

model Category {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  subtitle     String?
  imageUrl     String?
  description  String?
  productCount Int      @default(0)
  createdAt    DateTime @default(now())
}

model Order {
  id                  String   @id @default(cuid())
  userId              String
  items               String   // JSON string
  subtotal            Float
  advanceAmount       Float    @default(0)
  remainingAmount     Float    @default(0)
  paymentMethod       String   @default("full") // full, advance
  status              String   @default("pending_payment") // pending_payment, payment_submitted, under_review, approved, processing, shipped, delivered, cancelled
  customerName        String?
  customerPhone       String?
  customerEmail       String?
  customerAddress     String?
  customerCity        String?
  notes               String?
  trackingNumber      String?
  isReseller          Boolean  @default(false)
  profitAmount        Float    @default(0)
  paymentScreenshotUrl String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Review {
  id         String   @id @default(cuid())
  productId  String
  userId     String
  rating     Int
  title      String?
  content    String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
}

model PartnerApplication {
  id              String   @id @default(cuid())
  userId          String   @unique
  status          String   @default("pending") // pending, approved, rejected
  businessName    String?
  businessPhone   String?
  businessAddress String?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model PartnerPayout {
  id        String   @id @default(cuid())
  partnerId String
  amount    Float
  status    String   @default("pending") // pending, paid
  paidAt    DateTime?
  createdAt DateTime @default(now())

  partner User @relation(fields: [partnerId], references: [id])
}
